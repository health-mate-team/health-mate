  "production_priority_order": {
    "purpose": "20개 영상을 어떤 순서로 제작할지. 1순위부터 시작해 5단계로 그룹화.",
    "groups": [
      {
        "priority": 1,
        "videos": [
          "stretching_yoga × menstrual",
          "stretching_yoga × luteal",
          "light_cardio × follicular",
          "strength_training × follicular",
          "strength_training × ovulatory",
          "hiit × ovulatory"
        ],
        "rationale": "각 단계의 코어 운동. 사용자가 가장 자주 만날 추천."
      },
      {
        "priority": 2,
        "videos": [
          "stretching_yoga × follicular",
          "light_cardio × luteal",
          "strength_training × luteal",
          "breathing × menstrual",
          "breathing × luteal"
        ],
        "rationale": "사이클 후반·전반의 보조 추천. 코어 다음으로 자주 등장."
      },
      {
        "priority": 3,
        "videos": [
          "stretching_yoga × ovulatory",
          "light_cardio × menstrual",
          "hiit × follicular"
        ],
        "rationale": "보조·입문 콘텐츠. 사용자가 코어를 거부하거나 다양성 원할 때."
      },
      {
        "priority": 4,
        "videos": [
          "light_cardio × ovulatory",
          "breathing × follicular",
          "breathing × ovulatory"
