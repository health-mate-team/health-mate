{
  "$schema": "./schemas/workout_matrix.schema.json",
  "module": "workout_matrix",
  "version": "1.0.0",
  "purpose": "MVP에 필요한 운동 콘텐츠 명세. 4단계 × 운동 종류로 매트릭스 구성. 각 영상의 길이·강도·장비·촬영 비용 추정 포함.",
  "principle": "5분 이하, 한국 정서, 직장 휴식 시간에 가능. 30대 직장인 페인포인트 '시간 부족' 정조준.",

  "production_targets": {
    "mvp_v1_0_minimum": {
      "total_videos": 20,
      "rationale": "4단계 × 5종류 = 20. MVP 출시 최소량. 사용자가 한 사이클(28일) 동안 '겹치지 않는다'는 느낌 받게 하는 최소.",
      "production_cost_estimate_krw": "트레이너 1명 8시간 촬영 + 편집 외주 = 약 200-300만원",
      "production_method": "PT 트레이너 1명과 하루 일괄 촬영. 의상 4벌(단계별 컬러 코딩). 5분 영상 × 20개 = 약 100분 분량. 편집 시간 영상당 1시간 = 20시간."
    },
    "v1_1_expansion": {
      "total_videos": 40,
      "additions": "각 단계 × 종류에서 2개 옵션 (다양성). 후반에 '쿨다운', '워밍업' 카테고리 추가.",
      "trigger": "베타 H1 + H2 합격 후 제작 시작"
    }
  },

