  "production_pipeline": {
    "step_1_pre_production": {
      "tasks": [
        "트레이너 섭외 (1명, 여성, 펨테크 친화적 톤)",
        "스튜디오 예약 (자연광, 흰 배경 또는 코랄/베이지 톤)",
        "의상 준비 (4단계 컬러 코딩: 검정·베이지·코랄·라벤더)",
        "동작 시퀀스 1차 검토 (디자인팀 + 트레이너 합의)"
      ],
      "duration_days": 5
    },
    "step_2_filming": {
      "tasks": [
        "하루 일괄 촬영 (8시간)",
        "20개 영상 = 20개 take. 영상당 평균 25분 (촬영 + 의상 변경)",
        "B-roll 추가 (모아 캐릭터 합성용 빈 화면)"
      ],
      "duration_days": 1
    },
    "step_3_post": {
      "tasks": [
        "영상 편집 (영상당 1시간 × 20 = 20시간)",
        "오디오 가이드 녹음 (산책/호흡 영상용, 별도 5-7개)",
        "타이틀 카드·CTA 화면 디자인 (디자인팀)",
        "모아 캐릭터 인트로 / 아웃트로 합성 (디자인팀)"
      ],
      "duration_days": 7
    },
    "total_duration_days": 13,
    "total_cost_estimate_krw": "300-400만원",
    "fits_in_mvp_timeline": true
  },

  "fallback_for_no_video": {
    "purpose": "영상 제작 지연 시 MVP 출시 가능한 대안",
